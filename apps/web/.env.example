# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session encryption (Apple CalDAV passwords)
SESSION_SECRET=1234567898765432123456789

# --- Resend (Panic Mode exit emails) ---
# https://resend.com → API Keys → create key
# Verify a domain under Domains, then use an address on that domain.
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Stilo <notifications@yourdomain.com>

# --- OpenAI (Panic Mode image verification) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxx
# Optional: override vision model (default gpt-4o-mini)
# OPENAI_VISION_MODEL=gpt-4o-mini

# --- Google Calendar ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft Outlook ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
